  34          /***************写 100 命令函数***************
  35           * 帧格式: [1][0][0] + 8bit命令(MSB先) + 结束位
  36           * ********************************************/
  37          void write_cmd_100(unsigned char cmd)
  38          {
  39   1        unsigned char i;
  40   1        CS_LOW();
  41   1        WR_LOW();  TM1622_NOP(); DATA_HIGH(); TM1622_NOP(); WR_HIGH(); TM1622_NOP();
  42   1        WR_LOW();  TM1622_NOP(); DATA_LOW();  TM1622_NOP(); WR_HIGH(); TM1622_NOP();
  43   1        WR_LOW();  TM1622_NOP(); DATA_LOW();  TM1622_NOP(); WR_HIGH(); TM1622_NOP();
  44   1        for(i = 0; i < 8; i++)
  45   1        {
  46   2          WR_LOW();
  47   2          DATA_SET(cmd & 0x80);
  48   2          TM1622_NOP();
  49   2          WR_HIGH();
  50   2          cmd <<= 1;
