  54   1        CS_HIGH();
  55   1      }
  56          /***************写 101 数据函数***************
  57           * 帧格式: [1][0][1] + 6bit地址(MSB先) + 4bit数据(LSB先)
  58           * ********************************************/
  59          void write_101(unsigned char address, unsigned char dat)
