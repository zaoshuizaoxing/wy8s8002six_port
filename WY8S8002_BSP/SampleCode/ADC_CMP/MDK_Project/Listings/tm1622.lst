  66   1        WR_LOW();  TM1622_NOP(); DATA_HIGH(); TM1622_NOP(); WR_HIGH(); TM1622_NOP();
  67   1        for(i = 0; i < 6; i++)
  68   1        {
  69   2          WR_LOW();
