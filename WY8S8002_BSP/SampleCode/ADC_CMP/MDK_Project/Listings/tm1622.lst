  74   2        }
  75   1        for(i = 0; i < 4; i++)
  76   1        {
  77   2          WR_LOW();
  78   2          DATA_SET(dat & 0x01);
  79   2          WR_HIGH();
  80   2          TM1622_NOP();
  81   2          dat >>= 1;
  82   2        }
  83   1        WR_LOW();
  84   1        DATA_LOW();
  85   1        CS_HIGH();
  86   1      }
