  10          #include "common.h"
  11          #include "delay.h"
  12          #include "timer.h"
  13          
  14          /**
  15           * Generate a 1ms delay using Timer0
  16           * @param[in] u8Xms: Delay time in milliseconds (ms)
  17           * @note The parameter is of type uint8_t, thus the maximum support is a 255ms delay
  18           */
  19          void Timer0_Delay_ms(uint8_t u8Xms)
  20          {
  21   1          TIMER0_TMOD_MODE_SET(TIMER01_MODE1);
  22   1          ENABLE_TIMER0;
  23   1          while(u8Xms != 0) /* One loop equals 1ms */
  24   1          {
  25   2              TH0 = 0xE0;
  26   2              TL0 = 0xC0;
  27   2              while(IS_TIME0_OVER_FLAG != 1)
  28   2                  ;
  29   2              CLR_TIME0_OVER_FLAG;
  30   2              u8Xms--;
  31   2          }
  32   1          DISABLE_TIMER0;
  33   1      }


