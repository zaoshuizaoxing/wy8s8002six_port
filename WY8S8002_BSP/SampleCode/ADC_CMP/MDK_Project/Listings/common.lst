 150          /**
 151           * Fine-Tuning of HRC
 152           * @param[in] dir:
 153           * -# DIR_FREQ_UP: Fine-Tuning HRC frequency up
 154           * -# DIR_FREQ_DOWM: Fine-Tuning HRC frequency dowm
 155           * @param[in] step: Fine-Tuning step size
 156           * @not step range:0-1023
 157           * @return 0: Failure, 1: Success
 158           */
 159          uint8_t HRC_FineTuning(uint8_t dir, uint16_t step)
 160          {
 161   1        uint16_t fine_tune =  HRCFTUNE16 & 0x03FF;
 162   1        
 163   1        if(dir == DIR_FREQ_UP){ 
 164   2          fine_tune += step; 
 165   2          if(fine_tune > 0x03FF){
 166   3            return 0;
 167   3          }else{
 168   3            HRCFTUNE16 = (HRCFTUNE16 & 0xFC00) | fine_tune;
 169   3          }
 170   2        }else{ 
 171   2          if(fine_tune < step){
 172   3            return 0;
 173   3          }else{
 174   3            fine_tune -= step; 
 175   3            HRCFTUNE16 = (HRCFTUNE16 & 0xFC00) | fine_tune;
 176   3          }
 177   2        }
