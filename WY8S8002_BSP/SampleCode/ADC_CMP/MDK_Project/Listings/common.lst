  25           * -# CLK_DIV_32
  26           * -# CLK_DIV_64
  27           * -# CLK_DIV_128
  28           * @param[in] u8waits Flash access wait cycles
  29           * -# VDD >= 3.6V
  30           * -# WAITS_INST_VDD_GE3600MV_CLK_LT10M         Configuration for main frequency < 10MHz
  31           * -# WAITS_INST_VDD_GE3600MV_CLK_GE10_LT20M    Configuration for main frequency >= 10 and < 20MHz 
  32           * -# WAITS_INST_VDD_GE3600MV_CLK_GE20_LT30M    Configuration for main frequency >= 20 and < 30MHz 
  33           * -# WAITS_INST_VDD_GE3600MV_CLK_GE30_LT32M    Configuration for main frequency >= 30 and =< 32MHz 
  34           * -# VDD < 3.6V
  35           * -# WAITS_INST_VDD_LT3600MV_CLK_LT5M          Configuration for main frequency < 5MHz 
  36           * -# WAITS_INST_VDD_LT3600MV_CLK_GE5_LT10M     Configuration for main frequency >= 5 and < 10MHz 
  37           * -# WAITS_INST_VDD_LT3600MV_CLK_GE10_LT15M    Configuration for main frequency >= 10 and < 15MHz 
  38           * -# WAITS_INST_VDD_LT3600MV_CLK_GE15_LT20M    Configuration for main frequency >= 15 and < 20MHz
  39           * -# WAITS_INST_VDD_LT3600MV_CLK_GE20_LT25M    Configuration for main frequency >= 20 and < 25MHz  
  40           * -# WAITS_INST_VDD_LT3600MV_CLK_GE25_LT30M    Configuration for main frequency >= 25 and < 30MHz 
  41           * -# WAITS_INST_VDD_LT3600MV_CLK_GE30_LT32M    Configuration for main frequency >= 30 and =< 32MHz  
  42           *
  43           * @note When u8divSel = 0, CLK_sys is the clock source frequency
  44           * @note When u8divSel != 0, CLK_sys = clock source frequency / (2 * u8divSel)
  45           * @note If CLKSEL_OSC mode is selected, you need to change the external clock frequency in OSC_VALUE
  46           * @note If switching from a high frequency to a lower one, configure CLKCON before WAITSTS; if from low t
             -o high,
  47           * configure WAITSTS before CLKCON
  48           */
  49          void System_ConfigCLK(sysclk_t u8clkSel, uint8_t u8divSel, uint8_t u8waits)
