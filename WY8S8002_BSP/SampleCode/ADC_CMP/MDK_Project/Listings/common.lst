 148          /**
 149           * Fine-Tuning of HRC
 150           * @param[in] dir:
 151           * -# DIR_FREQ_UP: Fine-Tuning HRC frequency up
 152           * -# DIR_FREQ_DOWM: Fine-Tuning HRC frequency dowm
 153           * @param[in] step: Fine-Tuning step size
 154           * @not step range:0-1023
 155           * @return 0: Failure, 1: Success
 156           */
 157          uint8_t HRC_FineTuning(uint8_t dir, uint16_t step)
 158          {
 159   1        uint16_t fine_tune =  HRCFTUNE16 & 0x03FF;
 160   1        
 161   1        if(dir == DIR_FREQ_UP){ 
 162   2          fine_tune += step; 
 163   2          if(fine_tune > 0x03FF){
 164   3            return 0;
 165   3          }else{
 166   3            HRCFTUNE16 = (HRCFTUNE16 & 0xFC00) | fine_tune;
 167   3          }
 168   2        }else{ 
 169   2          if(fine_tune < step){
 170   3            return 0;
 171   3          }else{
 172   3            fine_tune -= step; 
 173   3            HRCFTUNE16 = (HRCFTUNE16 & 0xFC00) | fine_tune;
 174   3          }
 175   2        }
 176   1        return 1;
 177   1      }
