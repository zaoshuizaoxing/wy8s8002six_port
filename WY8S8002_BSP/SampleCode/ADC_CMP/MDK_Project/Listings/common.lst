  54   2              SYS_CLK_WAITS(u8waits);
  55   2          }
  56   1      
  57   1          switch(u8clkSel)
  58   1          {
  59   2              case SYSCLK_HRC:
  60   2                  SYS_CLK_SEL(CLKSEL_HRC);
  61   2                  DISABLE_HSE_CLK;
  62   2                  g_u32SystemClock = HRC_VALUE;
  63   2                  break;
  64   2              case SYSCLK_LRC:
