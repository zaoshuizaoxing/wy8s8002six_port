 103          /**
 104           * Starts loading PWM configuration
 105           * @param[in] u8pwmNum  PWM channel
 106           * -# PWM_0 - PWM_5
 107           * @note
 108           * Writing 1 to this bit automatically loads new configuration values at the end of the current PWM cycle.
             - Changed
 109           * configuration values, such as period, duty cycle, dead time, and mode, will take effect in the next cyc
             -le.
 110           */
 111          void PWM_StartLoad(uint8_t u8pwmNum)
 112          {
 113   1          switch(u8pwmNum)
 114   1          {
