  13          /**
  14           * Configures PWM interrupt
  15           * @param[in] u8pwmNum  PWM channel
  16           * -# PWM_0 - PWM_5
  17           * @param[in] u8trigger Interrupt trigger mode
  18           * -# PWM_FALLING_MODE    Falling edge on PWM0/1/2/3/4/5 pin
  19           * -# PWM_RISING_MODE     Rising edge on PWM0/1/2/3/4/5 pin
  20           * -# PWM_MIDPOINT_MODE   Midpoint of each PWM cycle
  21           * -# PWM_ENDPOINT_MODE   Endpoint of each PWM cycle
  22           * @note Midpoint or endpoint interrupt modes are only applicable in PWM center-aligned mode
  23           */
  24          void PWM_ConfigINT(uint8_t u8pwmNum, uint8_t u8trigger)
  25          {
  26   1          switch(u8pwmNum)
  27   1          {
  28   2              case PWM_0:
  29   2                  PWM_PWM0_INTTY_SET(u8trigger);
  30   2                  break;
  31   2              case PWM_1:
  32   2                  PWM_PWM1_INTTY_SET(u8trigger);
  33   2                  break;
  34   2              case PWM_2:
  35   2                  PWM_PWM2_INTTY_SET(u8trigger);
  36   2                  break;
  37   2              case PWM_3:
  38   2                  PWM_PWM3_INTTY_SET(u8trigger);
  39   2                  break;
  40   2              default:
  41   2                  break;
  42   2          }
  43   1      }
