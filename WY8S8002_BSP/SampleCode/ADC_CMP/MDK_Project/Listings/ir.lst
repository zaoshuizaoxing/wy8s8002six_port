  10          #include "ir.h"
  11          #include "pwm.h"
  12          #include "common.h"
  13          
  14          /** @brief  Carrier initialization of IR, The carrier of IR is generated by PWM.
  15           *  @param  CarrierFreq carrier frequency.
  16           *          This parameter value range: 30 - 60:
  17           *  @param  CarrierFreq carrier frequency.
  18           *          This parameter value range: 0 - 100:
  19           *  @retval None
  20           */
  21          static void _IR_PwmInit (uint8_t CarrierFreq, uint8_t CarrierDuty)
  22          {
  23   1          uint16_t period = (g_u32SystemClock/2/1000/CarrierFreq - 1) / 2;
  24   1          uint16_t duty = period  * (100-CarrierDuty) / 100;
  25   1      
  26   1          ENABLE_PWM;
  27   1          PWM_PWMCON_PWMMODE_SET(PWM_INDEPENDENT_MODE);
  28   1          PWM_CNTTYPE_SET(PWM_Mid_ALIGN_MODE);
  29   1          PWM0_FUNCTION_SELECTION(PWM_FUNC_PWM);
  30   1          PWM_CLKSEL_SET(PWM_CLK_PSC);
  31   1          PWM_PWMPSC01_DATA(1);
  32   1          PWM0_CNT_MODE_SET(AUTOLOAD_MODE);
  33   1          PWM_PWMP0HL_DATA((period >> 8) & 0xFF, period & 0xFF);
  34   1          PWM_PWMD0HL_DATA((duty >> 8) & 0xFF, duty & 0xFF);
  35   1          PWM_PWM0_INTTY_SET(PWM_ENDPOINT_MODE);
  36   1          ENABLE_PWM0_CNT;
  37   1          PWM_StartLoad(PWM_0);
  38   1      }
  39          
  40          /** @brief  IR initialization.
  41           *  @param  Init: IR initialization handle.
  42           *  @retval None
  43           */
  44          void IR_Init (const IR_Init_t* Init)
  45          {
  46   1          /* carrier setting */
  47   1          _IR_PwmInit(Init->CarrierFreq, Init->CarrierDuty);
  48   1          /* IR function selection : transmission */
  49   1          IR_FUNC_SEL(Init->Function);
  50   1      
  51   1          /* IR lcode0 signal type set. */
  52   1          IR_LCODE0_TYPE_SET(Init->Lcode0SignalType);
  53   1          /* IR lcode1 signal type set. */
  54   1          IR_LCODE1_TYPE_SET(Init->Lcode1SignalType);
