  47   2                  PORT_SET_MUX(ADC_AIN3_PORT, ANALOG_MUX_MODE);
  48   2                  ADC_ADCCON2_CHS_SEL(ADC_AIN3);
  49   2                  break;
  50   2              case ADC_AIN4:
  51   2                  PORT_SET_MUX(ADC_AIN4_PORT, ANALOG_MUX_MODE);
