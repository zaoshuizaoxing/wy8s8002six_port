  90          /**
  91           * Configure ADC Hardware Conversion Mode
  92           * @param[in] u8HWsource Hardware source for triggering ADC conversion
  93           * -# ADC_PWM0
  94           * -# ADC_PWM2
  95           * -# ADC_PWM4
  96           * -# ADC_STADC
  97           * @param[in] u8trigger Hardware trigger type
  98           * -# ADC_PWMSTA_RISING :    Rising edge of PWM0/2/4 or STADC pin
  99           * -# ADC_PWMSTA_FALLING:    Falling edge of PWM0/2/4 or STADC pin
 100           * -# ADC_PWM_MIDPOINT  : Midpoint of PWM0/2/4 cycle
 101           * -# ADC_PWM_ENDPOINT  : Endpoint of PWM0/2/4 cycle
 102           * @param[in] u8delay Hardware delay: total 10 bits, ADCCON2[1:0] for high 2 bits, ADDLYL[7:0] for low 8 b
             -its
 103           */
 104          void ADC_ConfigHWCVT(uint8_t u8HWsource, uint8_t u8trigger, uint16_t u16delay)
 105          {
 106   1          ADC_ADCCON0_SC_SET(ADC_HW_CVT_MODE); /* Select hardware conversion mode */
 107   1          ADC_ADCCON1_HWSSEL_SEL(u8HWsource);  /* Select hardware source for triggering ADC conversion */
 108   1          ADC_ADCCON1_HWTSEL_SEL(u8trigger);   /* Set hardware trigger type */
 109   1          ADC_ADDLY_DATA(u16delay);
 110   1      }
