  73          /**
  74           * Configure ADC Comparator Mode
  75           * @param[in] u8FBStatus ADC comparator result control for PWM brake enable
  76           * -# ADC_DISABLE_PWMFB: Disable
  77           * -# ADC_ENABLE_PWMFB:  Enable
  78           * @param[in] u8cmpSel ADC comparator output polarity selection
  79           * -# ADC_CR_GREATER_CMP_1: If ADRH, ADCRL >= ADCMP, then ADCMPO = 1, otherwise ADCMPO = 0
  80           * -# ADC_CR_LESS_CMP_1:    If ADRH, ADCRL < ADCMP, then ADCMPO = 1, otherwise ADCMPO = 0
  81           */
  82          void ADC_ConfigCMP(uint8_t u8FBStatus, uint8_t u8cmpSel)
  83          {
  84   1          ADC_ADCCON0_FBEN_SET(u8FBStatus);
  85   1          ADC_ADCCON0_PPS_SET(u8cmpSel);
  86   1      }
  87          /**
  88           * Configure ADC Hardware Conversion Mode
  89           * @param[in] u8HWsource Hardware source for triggering ADC conversion
  90           * -# ADC_PWM0
  91           * -# ADC_PWM2
  92           * -# ADC_PWM4
  93           * -# ADC_STADC
  94           * @param[in] u8trigger Hardware trigger type
  95           * -# ADC_PWMSTA_RISING :    Rising edge of PWM0/2/4 or STADC pin
  96           * -# ADC_PWMSTA_FALLING:    Falling edge of PWM0/2/4 or STADC pin
  97           * -# ADC_PWM_MIDPOINT  : Midpoint of PWM0/2/4 cycle
  98           * -# ADC_PWM_ENDPOINT  : Endpoint of PWM0/2/4 cycle
  99           * @param[in] u8delay Hardware delay: total 10 bits, ADCCON2[1:0] for high 2 bits, ADDLYL[7:0] for low 8 b
             -its
 100           */
 101          void ADC_ConfigHWCVT(uint8_t u8HWsource, uint8_t u8trigger, uint16_t u16delay)
 102          {
 103   1          ADC_ADCCON0_SC_SET(ADC_HW_CVT_MODE); /* Select hardware conversion mode */
 104   1          ADC_ADCCON1_HWSSEL_SEL(u8HWsource);  /* Select hardware source for triggering ADC conversion */
 105   1          ADC_ADCCON1_HWTSEL_SEL(u8trigger);   /* Set hardware trigger type */
 106   1          ADC_ADDLY_DATA(u16delay);
 107   1      }
