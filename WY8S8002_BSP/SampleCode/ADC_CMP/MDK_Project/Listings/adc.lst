  75          /**
  76           * Configure ADC Comparator Mode
  77           * @param[in] u8FBStatus ADC comparator result control for PWM brake enable
  78           * -# ADC_DISABLE_PWMFB: Disable
  79           * -# ADC_ENABLE_PWMFB:  Enable
  80           * @param[in] u8cmpSel ADC comparator output polarity selection
  81           * -# ADC_CR_GREATER_CMP_1: If ADRH, ADCRL >= ADCMP, then ADCMPO = 1, otherwise ADCMPO = 0
  82           * -# ADC_CR_LESS_CMP_1:    If ADRH, ADCRL < ADCMP, then ADCMPO = 1, otherwise ADCMPO = 0
  83           */
  84          void ADC_ConfigCMP(uint8_t u8FBStatus, uint8_t u8cmpSel)
  85          {
  86   1          ADC_ADCCON0_FBEN_SET(u8FBStatus);
  87   1          ADC_ADCCON0_PPS_SET(u8cmpSel);
  88   1      }
