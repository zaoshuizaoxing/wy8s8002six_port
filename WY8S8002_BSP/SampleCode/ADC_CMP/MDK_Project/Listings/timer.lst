  12          /**
  13           * Configures TIMER0 mode
  14           * @param[in] u8mode  Mode selection
  15           * -# TIMER01_MODE0  Mode 0, 13-bit Timer/Counter
  16           * -# TIMER01_MODE1  Mode 1, 16-bit Timer/Counter
  17           * -# TIMER01_MODE2  Mode 2, 8-bit Timer/Counter, reloads value from TH on TL overflow
  18           * -# TIMER01_MODE3  Mode 3, TL0 as 8-bit Timer/Counter (controlled by TIMER0), TH0 as 8-bit Timer/Counter
             - (controlled
  19           * by TIMER1)
  20           * @param[in] u8gate Gate control
  21           * -# TIMER01_TR_GATE:    Starts counting when TCON.TR0 is set to 1
  22           * -# TIMER01_INT_TR_GATE:Starts counting when both INT0 and TR0 are set to 1
  23           * @param[in] u8cnt Clock source selection
  24           * -# TIMER01_ICLK: As Timer0, the driving clock is from the internal clock input
  25           * -# TIMER01_TCLK: As Counter0, the driving clock is from the T0 pin input
  26           */
  27          void TIMER0_ConfigMode(uint8_t u8mode, uint8_t u8gate, uint8_t u8cnt)
  28          {
  29   1          TIMER0_TMOD_MODE_SET(u8mode);  /* Mode selection */
  30   1          TIMER0_TMOD_GATE0_SET(u8gate); /* Gate control */
  31   1          TIMER0_TMOD_CNT0_SET(u8cnt);   /* Clock source selection */
  32   1      }
  33          
  34          /**
