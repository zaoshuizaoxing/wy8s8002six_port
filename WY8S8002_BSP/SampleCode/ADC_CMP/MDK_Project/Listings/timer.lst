  48           */
  49          void TIMER1_ConfigMode(uint8_t u8mode, uint8_t u8gate, uint8_t u8cnt)
  50          {
  51   1          TIMER1_TMOD_MODE_SET(u8mode);  /* Mode selection */
  52   1          TIMER1_TMOD_GATE1_SET(u8gate); /* Gate control */
